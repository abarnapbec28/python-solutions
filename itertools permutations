from itertools import permutations

def print_permutations(s, r):
    sorted_s = sorted(s)
    perms = permutations(sorted_s, r)
    for p in perms:
        print("".join(p))

if __name__ == '__main__':
    try:
        user_input = input().rstrip().split()
    
        if len(user_input) == 2:
            input_string = user_input[0]
            input_r = int(user_input[1])
            print_permutations(input_string, input_r)
        else:
            print("Invalid input format. Please provide a string and an integer value separated by a space.")
    except ValueError:
        print("Invalid input. 'r' must be an integer.")
    except EOFError:
        print("No input provided.")
