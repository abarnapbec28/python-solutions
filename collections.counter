from collections import Counter
num_shoes = int(input())
shoes = Counter(map(int, input().split()))
num_customers = int(input())
total_income = 0
for _ in range(num_customers):
    size, price = map(int, input().split())
    if shoes[size] > 0:
        total_income += price
        shoes[size] -= 1
print(total_income)
