if __name__ == '__main__':
    s = "YourStringHere"
    s = input("")

has_alnum = False
has_alpha = False
has_digit = False
has_lower = False
has_upper = False

for char in s:
    if char.isalnum():
        has_alnum = True
    if char.isalpha():
        has_alpha = True
    if char.isdigit():
        has_digit = True
    if char.islower():
        has_lower = True
    if char.isupper():
        has_upper = True

print(f"{has_alnum}")
print(f"{has_alpha}")
print(f"{has_digit}")
print(f"{has_lower}")
print(f"{has_upper}")

